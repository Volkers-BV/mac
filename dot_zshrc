# shellcheck shell=bash
# Homebrew
if [ -x /opt/homebrew/bin/brew ]; then
  eval "$(/opt/homebrew/bin/brew shellenv)"
elif [ -x /usr/local/bin/brew ]; then
  eval "$(/usr/local/bin/brew shellenv)"
fi

# Composer global binaries
export PATH="$HOME/.composer/vendor/bin:$PATH"

# Bun
export BUN_INSTALL="$HOME/.bun"
export PATH="$BUN_INSTALL/bin:$PATH"

# fnvm — fast nvm wrapper with auto version switching (https://github.com/qwreey/fnvm)
export NVM_DIR="$HOME/.nvm"
export FNVM_DIR="$HOME/.fnvm"
if [ -s "$FNVM_DIR/fnvm.sh" ]; then
  # shellcheck source=/dev/null
  source "$FNVM_DIR/fnvm.sh"
  fnvm_init
  # fnvm only loads completions for bash; load them explicitly for zsh
  # shellcheck source=/dev/null
  [ -s "$NVM_DIR/bash_completion" ] && \. "$NVM_DIR/bash_completion"
else
  # Fallback to standard nvm if fnvm is not yet installed
  [ -s "$HOMEBREW_PREFIX/opt/nvm/nvm.sh" ] && \. "$HOMEBREW_PREFIX/opt/nvm/nvm.sh"
  [ -s "$HOMEBREW_PREFIX/opt/nvm/etc/bash_completion.d/nvm" ] && \. "$HOMEBREW_PREFIX/opt/nvm/etc/bash_completion.d/nvm"
fi

# Yarn global binaries
export PATH="$HOME/.yarn/bin:$PATH"

# --- Aliases ---

# Modern CLI replacements (only if installed)
command -v bat &>/dev/null && alias cat="bat --paging=never"
command -v eza &>/dev/null && alias ls="eza"
command -v eza &>/dev/null && alias ll="eza -la --git"
command -v eza &>/dev/null && alias lt="eza --tree --level=2"

# Navigation
alias ..="cd .."
alias ...="cd ../.."
alias ....="cd ../../.."

# Safety nets
alias cp="cp -i"
alias mv="mv -i"
alias rm="rm -i"

# Git shortcuts
alias gs="git status"
alias gd="git diff"
alias gl="git log --oneline -20"
alias gp="git pull"

# Networking
alias ip="curl -s https://ifconfig.me"
alias localip="ipconfig getifaddr en0"

# macOS utilities
alias flushdns="sudo dscacheutil -flushcache; sudo killall -HUP mDNSResponder"
alias emptytrash='command rm -rf ~/.Trash/* 2>/dev/null'
alias showfiles="defaults write com.apple.finder AppleShowAllFiles -bool true && killall Finder"
alias hidefiles="defaults write com.apple.finder AppleShowAllFiles -bool false && killall Finder"

# Reload shell
# SC2139: intentionally expand $SHELL at definition time (always points to current shell)
# shellcheck disable=SC2139
alias reload="exec $SHELL -l"

# fzf shell integration (Ctrl+R history, Ctrl+T file finder)
eval "$(fzf --zsh 2>/dev/null)"
